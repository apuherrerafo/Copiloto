# Anthropic (requerido para /api/chat en producción, p. ej. Vercel)
ANTHROPIC_API_KEY=

# Opcional: modelo Messages API (por defecto: claude-haiku-4-5-20251001)
# ANTHROPIC_CHAT_MODEL=claude-haiku-4-5-20251001

# Google AI Studio — solo para generar el splash local (npm run splash:gemini)
# GEMINI_API_KEY=
# Opcional: modelo de imagen nativo (Gemini 3.1 Flash Image)
# GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
