# Anthropic (requerido para /api/chat en producción, p. ej. Vercel)
ANTHROPIC_API_KEY=

# Opcional: modelo Messages API (por defecto: claude-haiku-4-5-20251001)
# ANTHROPIC_CHAT_MODEL=claude-haiku-4-5-20251001

# Google AI Studio — solo para generar el splash local (npm run splash:gemini)
# GEMINI_API_KEY=
# GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview

# --- Inicio de sesión con Google (NextAuth) — obligatorio para /entrar ---
# Consola: https://console.cloud.google.com/apis/credentials — OAuth 2.0 Web client
# URI de redirección autorizada:
#   http://localhost:3000/api/auth/callback/google
#   https://TU-DOMINIO.vercel.app/api/auth/callback/google
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# openssl rand -base64 32
# NEXTAUTH_SECRET=
# Local:  NEXTAUTH_URL=http://localhost:3000
# Vercel: NEXTAUTH_URL=https://TU-DOMINIO.vercel.app
# NEXTAUTH_URL=

# --- Supabase (sync multi-dispositivo + informe en la nube) ---
# Proyecto: https://supabase.com/dashboard — SQL: supabase/migrations/001_hypocopilot.sql
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=   # solo servidor (Vercel); nunca en el cliente
